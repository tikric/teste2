# =====================================================================
# BAMBUZAU - Variáveis de Ambiente
# =====================================================================
# Configure suas chaves no painel de Secrets do AI Studio
# ou em um arquivo .env local (NUNCA comite chaves reais no git)

# --- OBRIGATÓRIO para IA (escolha pelo menos um) ---

# Google Gemini AI (gemini.google.com/app → API Keys)
GEMINI_API_KEY=MY_GEMINI_API_KEY

# Anthropic Claude (console.anthropic.com → API Keys)
# Usado para busca de preços em tempo real com web search
ANTHROPIC_API_KEY=MY_ANTHROPIC_API_KEY

# --- BUSCADORES DE PREÇO (opcional, melhora muito os resultados) ---

# SerpAPI - Google Shopping real (serpapi.com)
# Plano gratuito: 100 buscas/mês
SERPAPI_API_KEY=MY_SERPAPI_KEY

# Tavily Search (tavily.com) - busca web avançada
# Plano gratuito disponível
TAVILY_API_KEY=MY_TAVILY_KEY

# Jina AI (jina.ai) - scraping web gratuito (funciona sem chave)
JINA_API_KEY=MY_JINA_KEY

# --- IA RÁPIDA / EXTRAÇÃO (opcional) ---

# Groq - LLM ultra-rápido para extração de preços (groq.com)
# Plano gratuito disponível
GROQ_API_KEY=MY_GROQ_KEY
